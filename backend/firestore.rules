rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Liste des pseudos Chess.com à surveiller. N'importe qui peut
    // s'ajouter (pas d'authentification dans ce projet), mais seuls
    // les champs attendus sont acceptés — pas de quoi faire de dégâts,
    // au pire quelqu'un ajoute un pseudo public en trop.
    match /users/{username} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['username', 'addedAt'])
                   && request.resource.data.username == username;
    }

    // Parties précalculées : lecture libre (ce sont des parties Chess.com
    // déjà publiques), mais écriture interdite depuis le navigateur —
    // seul le script GitHub Actions (via le compte de service Admin SDK,
    // qui ignore ces règles) a le droit d'écrire ici.
    match /games/{gameId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
